# ==============================================================================
# Umgebungs-Konfiguration (Coolify & VPS-Betrieb)
# Kopiere diese Datei in deine .env oder trage sie direkt bei Coolify ein.
# ==============================================================================

# ── DATENBANKEN ──────────────────────────────────────────────────────────────

# [OPTIONAL] Eigene PostgreSQL-Datenbank für den AI Support Agent
# Speichert Chats, Nachrichten, Wissenseinträge und Einstellungen.
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]
# HINWEIS: Wenn diese Variable LEER gelassen wird, weicht die App automatisch 
# auf eine lokale SQLite-Datenbank aus (empfohlen für einfaches Setup via Volume).
DATABASE_URL=postgresql://postgres:password@localhost:5432/esim_support_ai

# [WICHTIG / ERFORDERLICH] Exklusiver Lesezugriff auf die Storefront-Datenbank
# Wird verwendet, um Tarife und Preise für den AI-Wissens-Sync sowie Bestellungen auszulesen.
# Format: postgresql://[USER]:[PASSWORD]@[HOST]:[PORT]/[DB_NAME]
# HINWEIS: Trage hier die Verbindungsdaten der Storefront-Datenbank ein.
STOREFRONT-DB=postgresql://postgres:password@storefront-db-host:5432/storefront_db

# ── AI API CREDENTIALS ────────────────────────────────────────────────────────

# [WICHTIG / ERFORDERLICH] DeepSeek API-Schlüssel
# Haupt-Modell für Chat-Beratung und Kundensupport.
DEEPSEEK_API_KEY=your_deepseek_api_key

# [OPTIONAL] OpenAI API-Schlüssel
# Wird zur Generierung von Embeddings für die RAG-Wissensbasis verwendet.
# Wenn nicht angegeben, nutzt die App einen lokalen Cosine-Similarity Fallback in JavaScript.
OPENAI_API_KEY=your_openai_key_for_embeddings

# [OPTIONAL] xAI (Grok) API-Schlüssel
# Falls du Grok als alternatives Sprachmodell konfigurieren möchtest.
XAI_API_KEY=your_xai_api_key

# ── CHANNELS & BENACHRICHTIGUNGEN ─────────────────────────────────────────────

# [WICHTIG / ERFORDERLICH] Telegram Bot Token
# Token des Telegram-Bots für eSIM-Kunden-Support.
TELEGRAM_BOT_TOKEN=your_support_bot_token

# [WICHTIG / ERFORDERLICH] Web Push VAPID-Schlüssel (für Push-Benachrichtigungen im Dashboard)
# Kann erzeugt werden über: npm run generate-vapid
VAPID_PUBLIC_KEY=your_web_push_public_key
VAPID_PRIVATE_KEY=your_web_push_private_key

# ── DASHBOARD SICHERHEIT ──────────────────────────────────────────────────────

# [WICHTIG / ERFORDERLICH] Admin Dashboard Benutzername
# Login-Name für den Zugang unter /admin
ADMIN_USERNAME=admin

# [WICHTIG / ERFORDERLICH] Admin Dashboard Passwort
# Passwort für den Zugang unter /admin
ADMIN_PASSWORD=your_secure_password

# [WICHTIG / ERFORDERLICH] JWT Secret Key
# Ein sicherer, zufälliger String mit mindestens 32 Zeichen zur Signierung der Login-Sessions.
JWT_SECRET=some_random_32_character_string_for_jwt_signing_min_32_chars

# ── NETZWERK & ROUTING ────────────────────────────────────────────────────────

# [WICHTIG / ERFORDERLICH] Öffentliche URL dieses Support-Dienstes
# Die Domain, unter der das Support Dashboard & Widget erreichbar sein wird.
# HINWEIS: Für deine autoacts.link Konfiguration auf puresimaisupport.autoacts.link
APP_URL=https://puresimaisupport.autoacts.link

# [OPTIONAL] Lokaler Port
# Port auf dem die NodeJS-App lauscht (Standard: 3000). Coolify leitet diesen automatisch weiter.
PORT=3000

# [WICHTIG / ERFORDERLICH] Öffentliche URL deiner Storefront-Website
# Wird verwendet, um Kauflinks für eSIM-Tarife im Chat zu generieren.
STOREFRONT_URL=https://autoacts.link
